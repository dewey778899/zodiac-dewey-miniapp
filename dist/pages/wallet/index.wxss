.wallet-card{background:radial-gradient(circle at top right,rgba(200,182,226,.16),transparent 28%),linear-gradient(145deg,hsla(0,0%,100%,.94),rgba(255,244,248,.94));border:1rpx solid rgba(255,181,167,.18);padding:32rpx 26rpx}.wallet-field{margin-top:20rpx}.wallet-label{color:#6b4f60;display:block;font-size:24rpx;margin-bottom:10rpx}.wallet-input-wrap{align-items:center;background:hsla(0,0%,100%,.92);border:2rpx solid hsla(8,100%,74%,.44);border-radius:24rpx;box-shadow:0 10rpx 24rpx rgba(155,127,199,.12);box-sizing:border-box;display:flex;gap:12rpx;min-height:96rpx;padding:0 18rpx 0 22rpx}.wallet-input-prefix{color:#c47a7a;font-size:30rpx;font-weight:800}.wallet-input{background:transparent;border:0;box-sizing:border-box;color:#3d2a35;flex:1;font-size:36rpx;font-weight:800;min-height:88rpx;padding:0}.wallet-input-edit{background:rgba(255,181,167,.18);border-radius:999rpx;color:#8c5c6d;font-size:22rpx;padding:8rpx 14rpx;white-space:nowrap}.wallet-field-hint{color:#8c6d7b;display:block;font-size:23rpx;margin-top:10rpx}.wallet-actions{display:flex;flex-direction:column;gap:16rpx;margin-top:20rpx}.wallet-share-button{border:0;margin:0;padding:0}.wallet-share-button::after{border:0}.wallet-summary{background:hsla(0,0%,100%,.72);border:1.5rpx solid rgba(255,181,167,.18);border-radius:24rpx;margin-top:24rpx;padding:22rpx}.wallet-line{color:#4e3a47;display:block;font-size:24rpx;margin-top:8rpx}.wallet-line-strong{color:#c05e75;font-weight:800}.wallet-section{margin-top:26rpx}.wallet-section-title{color:#3d2a35;display:block;font-size:28rpx;font-weight:700;margin-bottom:12rpx}.wallet-record{align-items:center;background:hsla(0,0%,100%,.72);border:1rpx solid rgba(255,181,167,.14);border-radius:20rpx;color:#6b4f60;display:flex;font-size:24rpx;justify-content:space-between;margin-top:10rpx;padding:18rpx 20rpx}.wallet-empty{color:#9a7a8d;display:block;font-size:24rpx;margin-top:10rpx}