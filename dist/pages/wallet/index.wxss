.wallet-card{background:radial-gradient(circle at top right,rgba(200,182,226,.16),transparent 28%),linear-gradient(145deg,hsla(0,0%,100%,.94),rgba(255,244,248,.94));border:1rpx solid rgba(255,181,167,.18);padding:32rpx 26rpx}.wallet-field{margin-top:20rpx}.wallet-label{color:#6b4f60;display:block;font-size:24rpx;margin-bottom:10rpx}.wallet-input{background:hsla(0,0%,100%,.74);border:1.5rpx solid rgba(255,181,167,.26);border-radius:24rpx;box-sizing:border-box;color:#3d2a35;font-size:28rpx;min-height:88rpx;padding:0 24rpx}.wallet-actions{display:flex;flex-direction:column;gap:16rpx;margin-top:20rpx}.wallet-summary{background:hsla(0,0%,100%,.72);border:1.5rpx solid rgba(255,181,167,.18);border-radius:24rpx;margin-top:24rpx;padding:22rpx}.wallet-line{color:#4e3a47;display:block;font-size:24rpx;margin-top:8rpx}.wallet-section{margin-top:26rpx}.wallet-section-title{color:#3d2a35;display:block;font-size:28rpx;font-weight:700;margin-bottom:12rpx}.wallet-record{align-items:center;background:hsla(0,0%,100%,.72);border:1rpx solid rgba(255,181,167,.14);border-radius:20rpx;color:#6b4f60;display:flex;font-size:24rpx;justify-content:space-between;margin-top:10rpx;padding:18rpx 20rpx}.wallet-empty{color:#9a7a8d;display:block;font-size:24rpx;margin-top:10rpx}