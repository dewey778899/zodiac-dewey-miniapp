.home-hero{background:radial-gradient(circle at top right,rgba(255,181,167,.24),transparent 34%),linear-gradient(145deg,hsla(0,0%,100%,.92),rgba(255,244,248,.94) 52%,rgba(247,236,252,.94));border:1rpx solid rgba(255,181,167,.24);padding:34rpx 28rpx}.hero-tag{align-items:center;background:rgba(255,181,167,.18);border:1.5rpx solid hsla(8,100%,74%,.24);border-radius:999rpx;color:#ff8b7a;display:inline-flex;font-size:20rpx;font-weight:700;letter-spacing:2rpx;padding:8rpx 20rpx}.home-panel{margin-top:24rpx;padding:28rpx 24rpx}.panel-title{color:#3d2a35;display:block;font-size:30rpx;font-weight:800}.status-list{display:flex;flex-direction:column;gap:16rpx;margin-top:20rpx}.status-item{align-items:center;background:hsla(0,0%,100%,.72);border:1rpx solid rgba(255,181,167,.22);border-radius:22rpx;display:flex;gap:14rpx;padding:18rpx 20rpx}.status-dot{border-radius:999rpx;flex:0 0 18rpx;height:18rpx;width:18rpx}.status-dot.success{background:#07c160}.status-dot.warn{background:#ff9f43}.status-text{color:#4d3441;font-size:26rpx}.quick-grid{display:grid;gap:16rpx;grid-template-columns:repeat(2,minmax(0,1fr));margin-top:20rpx}.quick-card{background:radial-gradient(circle at top right,rgba(155,127,199,.12),transparent 30%),hsla(0,0%,100%,.84);border:1rpx solid rgba(255,181,167,.24);border-radius:24rpx;box-sizing:border-box;display:flex;flex-direction:column;justify-content:space-between;min-height:148rpx;padding:24rpx 20rpx}.quick-card-title{color:#3d2a35;font-size:28rpx;font-weight:700}.quick-card-subtitle{color:#7e6574;font-size:22rpx}.home-actions{display:flex;flex-direction:column;gap:16rpx;margin-top:24rpx}