.payment-card{background:radial-gradient(circle at top right,rgba(7,193,96,.12),transparent 28%),radial-gradient(circle at bottom left,rgba(255,181,167,.18),transparent 26%),linear-gradient(145deg,hsla(0,0%,100%,.94),rgba(255,244,248,.94));border:1rpx solid rgba(255,181,167,.22);padding:30rpx 26rpx}.payment-tag{align-items:center;background:rgba(7,193,96,.14);border:1.5rpx solid rgba(7,193,96,.24);border-radius:999rpx;color:#5de1a6;display:inline-flex;font-size:20rpx;font-weight:700;justify-content:center;letter-spacing:2rpx;padding:8rpx 18rpx}.payment-price-block{align-items:flex-end;display:flex;gap:8rpx;justify-content:center;margin-top:26rpx}.payment-price-symbol{color:#7d5fb3;font-size:34rpx;line-height:1.1}.payment-price-value{color:#3d2a35;font-family:SimSun,STSong,"Noto Serif SC",serif;font-size:96rpx;line-height:1}.payment-grid{display:flex;flex-direction:column;gap:16rpx;margin-top:24rpx}.payment-item{background:hsla(0,0%,100%,.72);border:1rpx solid rgba(255,181,167,.18);border-radius:24rpx;padding:22rpx 24rpx}.payment-item-title{color:#3d2a35;font-size:30rpx;font-weight:600}.payment-item-subtitle{color:#6b4f60;display:block;font-size:24rpx;line-height:1.7;margin-top:8rpx}.payment-actions{display:flex;flex-direction:column;gap:14rpx;margin-top:22rpx}.payment-actions .button-primary{background:linear-gradient(135deg,#07c160,#0fbf76);box-shadow:0 10rpx 28rpx rgba(7,193,96,.24)}.payment-actions .button-primary::before{background:hsla(0,0%,100%,.22);border-radius:50%;box-shadow:inset 0 0 0 6rpx #fff;content:"";height:26rpx;margin-right:10rpx;width:26rpx}.payment-wechat-button{letter-spacing:1rpx;position:relative}.payment-wechat-button:active{box-shadow:0 6rpx 20rpx rgba(7,193,96,.22);transform:translateY(2rpx)}.payment-actions .button-secondary{background:hsla(0,0%,100%,.76);border-color:rgba(255,181,167,.22);color:#6b4f60}.payment-status{color:#6b4f60;font-size:24rpx;margin-top:20rpx;white-space:pre-wrap;word-break:break-all}.payment-meta{color:#9a7a8d;display:block;font-size:22rpx;margin-top:18rpx;word-break:break-all}