page{background:linear-gradient(135deg,#fff5f0,#fde4ea 35%,#f4e0f5 70%,#e8e0f7);color:#3d2a35;font-family:"Noto Serif SC",Songti SC,"Source Han Serif SC",-apple-system,BlinkMacSystemFont,PingFang SC,serif}.page-shell{background:radial-gradient(circle at top right,rgba(255,181,167,.15),transparent 30%),radial-gradient(circle at bottom left,rgba(200,182,226,.16),transparent 32%),linear-gradient(135deg,#fff5f0,#fde4ea 35%,#f4e0f5 70%,#e8e0f7);box-sizing:border-box;min-height:100vh;padding:32rpx 20rpx 48rpx}.card{backdrop-filter:blur(20rpx);background:hsla(0,0%,100%,.76);border:1rpx solid hsla(0,0%,100%,.64);border-radius:28rpx;box-shadow:0 12rpx 40rpx rgba(155,127,199,.12)}.section-title{color:#3d2a35;font-size:36rpx;font-weight:900}.section-subtitle{color:#6b4f60;font-size:24rpx;line-height:1.7;margin-top:10rpx}.button-primary{align-items:center;background:linear-gradient(135deg,#ff8b7a,#9b7fc7);border-radius:999rpx;box-shadow:0 10rpx 28rpx rgba(155,127,199,.24);color:#fff;display:flex;font-size:30rpx;font-weight:700;height:92rpx;justify-content:center}.button-secondary{align-items:center;background:hsla(0,0%,100%,.8);border:1.5rpx solid rgba(255,181,167,.3);border-radius:999rpx;color:#3d2a35;display:flex;font-size:28rpx;font-weight:600;height:84rpx;justify-content:center}.pill-tabs{display:flex;gap:12rpx}.pill-tab{align-items:center;background:hsla(0,0%,100%,.7);border:1.5rpx solid rgba(255,181,167,.22);border-radius:24rpx;color:#6b4f60;display:flex;flex:1;font-size:28rpx;height:84rpx;justify-content:center}.pill-tab.active{background:linear-gradient(135deg,#ffb5a7,#c8b6e2);border-color:transparent;color:#fff}