.report-cover{background:radial-gradient(circle at top right,rgba(255,181,167,.16),transparent 34%),radial-gradient(circle at bottom left,rgba(200,182,226,.12),transparent 36%),linear-gradient(180deg,rgba(255,250,248,.98),rgba(248,240,246,.96));padding:34rpx 28rpx}.report-cover-kicker{color:#c47a7a;font-size:20rpx;letter-spacing:4rpx}.report-cover-title{color:#352733;display:block;font-size:42rpx;font-weight:800;margin-top:16rpx}.report-cover-score-row{align-items:flex-end;display:flex;gap:8rpx;justify-content:center;margin-top:20rpx}.report-cover-score{color:#2f2630;font-family:SimSun,STSong,"Noto Serif SC",serif;font-size:110rpx;line-height:1}.report-cover-score-unit{color:#8b6e7d;font-size:28rpx;padding-bottom:16rpx}.report-cover-tagline,.report-cover-type{display:block;text-align:center}.report-cover-type{color:#4d3a49;font-size:28rpx;margin-top:10rpx}.report-cover-tagline{color:#7a6070;font-size:24rpx;line-height:1.7;margin-top:10rpx}.report-cover-people{align-items:center;display:flex;gap:18rpx;justify-content:center;margin-top:26rpx}.report-cover-people.single{justify-content:center}.report-cover-person{align-items:center;display:flex;flex-direction:column;min-width:180rpx;text-align:center}.report-cover-symbol{color:#cc7d8f;font-size:56rpx}.report-cover-zodiac{color:#8b6e7d;font-size:22rpx;margin-top:10rpx}.report-cover-name{color:#342832;font-size:30rpx;font-weight:700;margin-top:8rpx}.report-cover-heart{color:#c47a7a;font-size:36rpx}.report-cover-meta{border-top:1rpx solid rgba(197,127,147,.16);display:flex;flex-direction:column;gap:8rpx;margin-top:28rpx;padding-top:18rpx;text-align:center}.report-cover-meta-label{color:#9a7b89;font-size:20rpx;letter-spacing:3rpx}.report-cover-meta-value{color:#352733;font-size:24rpx}.report-cover-meta-date{color:#8b6e7d;font-size:22rpx}