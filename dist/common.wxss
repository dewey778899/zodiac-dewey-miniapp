.report-cover{background:radial-gradient(circle at top right,rgba(89,213,255,.12),transparent 32%),linear-gradient(180deg,rgba(10,21,38,.9),rgba(7,17,29,.92));padding:34rpx 28rpx}.report-cover-kicker{color:#59d5ff;font-size:20rpx;letter-spacing:4rpx}.report-cover-title{color:#edf6ff;display:block;font-size:42rpx;font-weight:800;margin-top:16rpx}.report-cover-score-row{align-items:flex-end;display:flex;gap:8rpx;justify-content:center;margin-top:20rpx}.report-cover-score{color:#edf6ff;font-family:SimSun,STSong,"Noto Serif SC",serif;font-size:110rpx;line-height:1}.report-cover-score-unit{color:#88a6c7;font-size:28rpx;padding-bottom:16rpx}.report-cover-tagline,.report-cover-type{display:block;text-align:center}.report-cover-type{color:#cfe3f9;font-size:28rpx;margin-top:10rpx}.report-cover-tagline{color:#8ea7c6;font-size:24rpx;line-height:1.7;margin-top:10rpx}.report-cover-people{align-items:center;display:flex;gap:18rpx;justify-content:center;margin-top:26rpx}.report-cover-people.single{justify-content:center}.report-cover-person{align-items:center;display:flex;flex-direction:column;min-width:180rpx;text-align:center}.report-cover-symbol{color:#59d5ff;font-size:56rpx}.report-cover-zodiac{color:#8ea7c6;font-size:22rpx;margin-top:10rpx}.report-cover-name{color:#edf6ff;font-size:30rpx;font-weight:700;margin-top:8rpx}.report-cover-heart{color:#8db7ff;font-size:36rpx}.report-cover-meta{border-top:1rpx solid rgba(89,213,255,.12);display:flex;flex-direction:column;gap:8rpx;margin-top:28rpx;padding-top:18rpx;text-align:center}.report-cover-meta-label{color:#88a6c7;font-size:20rpx;letter-spacing:3rpx}.report-cover-meta-value{color:#edf6ff;font-size:24rpx}.report-cover-meta-date{color:#8ea7c6;font-size:22rpx}